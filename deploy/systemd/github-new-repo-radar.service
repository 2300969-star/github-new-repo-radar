[Unit]
Description=GitHub New Repo Radar daily report
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
Environment=GITHUB_RADAR_OUTPUT_DIR=/opt/github-new-repo-radar/reports
Environment=GITHUB_RADAR_LIMIT=20
Environment=GITHUB_RADAR_TIMEZONE=Asia/Shanghai
WorkingDirectory=/opt/github-new-repo-radar
ExecStart=/usr/local/bin/github-new-repo-radar-daily

